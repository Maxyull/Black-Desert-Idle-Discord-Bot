# Copie ce fichier en ".env" en local, ou configure ces mêmes variables dans le
# panneau de ton hébergeur (Pella : onglet "Variables"/"Environment"). Ne JAMAIS
# committer le vrai fichier ".env" (déjà exclu par .gitignore).

# Discord Developer Portal > ton application > Bot > Reset Token
DISCORD_TOKEN=

# Discord Developer Portal > ton application > General Information > Application ID
DISCORD_CLIENT_ID=

# ID du serveur Discord où déployer les commandes slash (clic droit sur le serveur
# en mode développeur > Copier l'identifiant du serveur). Optionnel : si vide, les
# commandes sont déployées globalement (peut prendre jusqu'à 1h pour apparaître).
DISCORD_GUILD_ID=

# Annonces de nouvelle version, un salon par langue
DISCORD_PATCHNOTE_FR_CHANNEL_ID=1515434369224016012
DISCORD_PATCHNOTE_EN_CHANNEL_ID=1515439814122537111

# ID du salon où poster les signalements de bug (/bug — ancien système texte simple)
DISCORD_BUG_CHANNEL_ID=

# ID du salon Forum où poster les suggestions (/suggestion — ancien système dédié)
DISCORD_SUGGESTIONS_CHANNEL_ID=

# Forums communautaires COMBINÉS bug + suggestion, un par langue — quand un joueur crée
# directement un post dans l'un de ces forums (sans passer par /bug ou /suggestion) et lui
# applique le tag "Suggestion", le bot réagit automatiquement avec 👍 👎 🤷
DISCORD_COMMUNITY_FORUM_FR_ID=1522414587910160404
DISCORD_COMMUNITY_FORUM_EN_ID=1522414464811532428

# Relais de traduction automatique : tout message posté dans le salon FR est
# retranscrit en anglais dans le salon EN (nécessite le "Message Content Intent"
# activé dans Discord Developer Portal > ton appli > Bot)
DISCORD_FR_CHANNEL_ID=1515449365135888505
DISCORD_EN_CHANNEL_ID=1522411682343813241

# Supabase > Project Settings > API > Project URL
SUPABASE_URL=

# Supabase > Project Settings > API > service_role key (SECRET — ne jamais exposer
# côté client/navigateur, contrairement à la clé "anon" utilisée dans index.html.
# Cette clé contourne toutes les règles RLS, elle ne doit vivre que dans ce bot).
SUPABASE_SERVICE_ROLE_KEY=

# URL publique du jeu, utilisée pour détecter les nouvelles versions déployées
GAME_URL=https://maxyull.github.io/black-desert-idle/

# Valeur partagée avec le jeu (index.html) pour l'endpoint POST /join-guild — génère une
# chaîne aléatoire (ex: openssl rand -hex 32) et reporte EXACTEMENT la même valeur dans la
# constante BOT_API_SECRET du jeu. ATTENTION : comme index.html est un fichier public sur
# GitHub Pages, cette valeur N'EST PAS un vrai secret (n'importe qui peut la lire en
# affichant le code source) — elle sert juste de filtre basique anti-spam sur l'endpoint.
# La vraie sécurité vient de Discord lui-même : un access_token invalide/expiré/sans le
# bon scope est rejeté par son API quoi qu'il arrive, peu importe qui appelle l'endpoint.
INTERNAL_API_SECRET=
